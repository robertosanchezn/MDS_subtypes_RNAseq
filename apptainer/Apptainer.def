Bootstrap: docker
from: rocker/tidyverse:4.3

%post
    # 1. Install System Dependencies (CRITICAL for Bioinfo packages)
    apt-get update && apt-get install -y --no-install-recommends \
        libxml2-dev \
        libglpk-dev \
        libxt-dev \
        libboost-all-dev \
        libgsl-dev \
        cmake \
        git

    # 2. Setup Conda/Mamba
    wget -O Miniforge3.sh "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-$(uname)-$(uname -m).sh"
    bash Miniforge3.sh -b -p "/opt/conda"
    rm Miniforge3.sh

    export PATH="/opt/conda/bin:$PATH"
    conda config --system --prepend channels conda-forge
    conda config --system --prepend channels bioconda

    conda install -n base -y mamba

    # 3. Install core analytical suite
    mamba install -n base -y \
	    r-tidyverse \
        r-hdf5r \
        r-seurat \
        bioconda::r-presto \
        bioconda::bioconductor-limma \
        bioconda::bioconductor-preprocesscore \
        bioconda::bioconductor-org.hs.eg.db \
        bioconda::bioconductor-clusterprofiler \
        bioconda::bioconductor-geoquery 

    # 4. Cleanup
    mamba clean -a -y

%environment
    export PATH=/opt/conda/bin:$PATH
    export LD_LIBRARY_PATH=/opt/conda/lib:$LD_LIBRARY_PATH

%runscript
    exec R "$@"

%test
    Rscript -e "library(Seurat); library(limma);  library(preprocessCore)"

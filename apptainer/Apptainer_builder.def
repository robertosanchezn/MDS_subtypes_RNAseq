Bootstrap: docker
from: rocker/tidyverse@sha256:8549448d4bb48663d1148b3acf9d1e001b61aceb6f0a6872dbbdcada2530da56

%post
    # 1. Install System Dependencies 
    apt-get update && apt-get install -y --no-install-recommends \
        libxml2-dev \
        libglpk-dev \
        libxt-dev \
        libboost-all-dev \
        libgsl-dev \
        cmake \
        git

    # 2. Setup Conda/Mamba
    wget -O Miniforge3.sh "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-$(uname)-$(uname -m).sh"
    bash Miniforge3.sh -b -p "/opt/conda"
    rm Miniforge3.sh

    export PATH="/opt/conda/bin:$PATH"
    conda config --system --prepend channels conda-forge
    conda config --system --prepend channels bioconda

    conda install -n base -y mamba

    # 3. Install libraries
    mamba install --yes \
        r-tidyverse \
        r-gt \
        r-hdf5r \
        r-seurat \
        r-rmdformats \
        r-biocmanager \
        r-dirichletreg \
        bioconda::bioconductor-go.db \
        bioconda::bioconductor-limma \
        bioconda::bioconductor-fgsea \
        bioconda::bioconductor-geoquery \
        bioconda::bioconductor-org.hs.eg.db \
        bioconda::bioconductor-preprocesscore \
        bioconda::bioconductor-complexheatmap \
        bioconda::bioconductor-clusterprofiler \
        bioconda::bioconductor-genomeinfodbdata \

    mamba clean -a -y

%environment
    export PATH=/opt/conda/bin:$PATH
    export LD_LIBRARY_PATH=/opt/conda/lib:$LD_LIBRARY_PATH

%runscript
    exec R "$@"

%test
    Rscript -e "library(Seurat)"
    Rscript -e "library(GenomeInfoDbData)"
    Rscript -e "library(DirichletReg)"
    Rscript -e "library(clusterProfiler)"

